{
  "name": "nextjs-hybrid-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:api": "cd api && npm run build",
    "swa:all": "cross-env AZURE_CLIENT_ID=local-dev-client-id AZURE_CLIENT_SECRET=local-dev-client-secret swa start",
    "swa:build": "npm run build && (cd api && npm run build)",
    "swa:start": "swa start out --api-location api",
    "test:e2e": "WITH_API=true npx playwright test",
    "test:e2e:headed": "WITH_API=true npx playwright test --headed",
    "test:e2e:mock": "npx playwright test",
    "test:e2e:mock:headed": "npx playwright test --headed",
    "test:e2e:swa": "npx playwright test --config=playwright.config.swa.ts",
    "test:e2e:swa:headed": "npx playwright test --config=playwright.config.swa.ts --headed",
    "test:e2e:no-auth": "WITH_API=true npx playwright test --config=playwright.config.no-auth.ts",
    "test:e2e:no-auth:headed": "WITH_API=true npx playwright test --config=playwright.config.no-auth.ts --headed",
    "test:e2e:sansu": "npx playwright test --config=playwright.config.sansu.ts",
    "test:e2e:sansu:headed": "npx playwright test --config=playwright.config.sansu.ts --headed",
    "dev:with-api": "npm run build:api && swa start http://localhost:3000 --api-location api --run \"npm run dev\"",
    "sansu:stop": "pkill -f 'azurite' 2>/dev/null; pkill -f 'swa start' 2>/dev/null; pkill -f 'func start' 2>/dev/null; lsof -ti:4280,7071,3000,10000,10001,10002 | xargs kill -9 2>/dev/null; sleep 1; echo 'stopped.'",
    "sansu:dev": "npm run sansu:stop && mkdir -p /tmp/azurite-sansu && (azurite --location /tmp/azurite-sansu --loose > /tmp/azurite.log 2>&1 &) && sleep 1 && npm run build:api && swa start http://localhost:3000 --api-location api --run \"npm run dev\"",
    "sansu:admin": "node api/scripts/sansu-admin.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "balance:pakupaku": "tsx scripts/balance/pakupaku-sim.ts",
    "balance:kurukurin": "tsx scripts/balance/kurukurin-sim.ts",
    "balance:flappy": "tsx scripts/balance/flappy-sim.ts",
    "balance:snake": "tsx scripts/balance/snake-sim.ts",
    "balance:runner": "tsx scripts/balance/runner-sim.ts",
    "balance:falling": "tsx scripts/balance/falling-sim.ts",
    "balance:breakout": "tsx scripts/balance/breakout-sim.ts",
    "balance:whack": "tsx scripts/balance/whack-sim.ts",
    "balance:airhockey": "tsx scripts/balance/airhockey-sim.ts",
    "balance:starshooter": "tsx scripts/balance/starshooter-sim.ts",
    "balance:ponpon": "tsx scripts/balance/ponpon-sim.ts",
    "balance:maze": "tsx scripts/balance/maze-sim.ts",
    "balance:memory": "tsx scripts/balance/memory-sim.ts",
    "balance:rhythmdon": "tsx scripts/balance/rhythmdon-sim.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "canvas": "^3.1.0",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.40.0",
    "highlight.js": "^11.11.1",
    "next": "^15.5.10",
    "next-pwa": "^5.6.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.0.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.4",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unicorn": "^48.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.1.2",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.18.0 || >=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaotiantakumi/SwaSnapContent.git"
  }
}
